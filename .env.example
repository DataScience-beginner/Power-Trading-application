DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Optional Railway-style variables if DATABASE_URL is not used:
# PGHOST=
# PGUSER=
# PGPASSWORD=
# PGDATABASE=
# PGPORT=5432

# Optional: auto-load mock data on API startup
AUTO_LOAD_MOCK_DATA=false

# Required to enable protected AI Foundation V1 data operations.
# Generate a long random value per environment; never commit the real key.
AI_FOUNDATION_API_KEY=replace-with-a-secure-random-value

# SaaS user JWT signing. Generate independently from all other keys.
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_EXPIRE_MINUTES=480
IDENTITY_TOKEN_PEPPER=replace-with-an-independent-32-plus-character-random-value
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
APP_BASE_URL=http://localhost:5173
ENABLE_DEMO_PROVISIONING=false
ENABLE_DATABASE_RESET=false

# Optional free-tier Groq narration. Deterministic chatbot tools work without it.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Enterprise account-recovery delivery. Leave unset to fail closed without sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USERNAME=
SMTP_PASSWORD=
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=

# Security controls. Production should enable rate limiting and require antivirus scanning.
RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=20
UPLOAD_RATE_LIMIT_PER_MINUTE=20
UPLOAD_MAX_BYTES=26214400
CLAMAV_SCAN_ENABLED=false
CLAMAV_SCAN_REQUIRED=false
ALLOW_MACRO_FILES=false

# Secure browser sessions and TOTP MFA. Generate MFA_ENCRYPTION_KEY with
# `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`.
AUTH_COOKIE_ENABLED=true
AUTH_COOKIE_NAME=innowatt_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
MFA_ENCRYPTION_KEY=
MFA_ISSUER=Innowatt Energy AI
MFA_REQUIRED_FOR_ADMIN=false

# Public-edge and bot controls. Enable WAF verification only after the selected
# edge provider injects the matching secret header over a trusted origin path.
WAF_VERIFICATION_REQUIRED=false
WAF_VERIFICATION_SECRET=
SECURITY_ALERT_WEBHOOK_URL=
SECURITY_ALERT_WEBHOOK_TOKEN=
API_TENANT_DAILY_QUOTA=100000

# Enterprise identity integration contracts. Keep provider secrets in the
# environment secret store, never in this file.
IDENTITY_PROVIDER_NAME=
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
SAML_METADATA_URL=
SAML_METADATA_XML=
SCIM_BEARER_TOKEN=
PASSKEYS_ENABLED=false
MANAGED_DEVICE_REQUIRED=false
ALLOWED_LOGIN_DOMAINS=
SECURITY_AUDIT_RETENTION_NOTE=

# Identity delivery: use mock for local/TEST; use provider in production.
IDENTITY_DELIVERY_MODE=mock
