DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Optional Railway-style variables if DATABASE_URL is not used:
# PGHOST=
# PGUSER=
# PGPASSWORD=
# PGDATABASE=
# PGPORT=5432

# Optional: auto-load mock data on API startup
AUTO_LOAD_MOCK_DATA=false

# Required to enable protected AI Foundation V1 data operations.
# Generate a long random value per environment; never commit the real key.
AI_FOUNDATION_API_KEY=replace-with-a-secure-random-value

# SaaS user JWT signing. Generate independently from all other keys.
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_EXPIRE_MINUTES=480
IDENTITY_TOKEN_PEPPER=replace-with-an-independent-32-plus-character-random-value
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
APP_BASE_URL=http://localhost:5173
ENABLE_DEMO_PROVISIONING=false
ENABLE_DATABASE_RESET=false

# Optional free-tier Groq narration. Deterministic chatbot tools work without it.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Enterprise account-recovery delivery. Leave unset to fail closed without sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USERNAME=
SMTP_PASSWORD=
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
