{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Power Trading Agent Registry",
  "type": "object",
  "required": ["version", "agents"],
  "properties": {
    "version": { "type": "integer" },
    "updated_at": { "type": "string" },
    "governance": { "type": "object" },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "version", "owner", "purpose", "triggers", "instruction_files"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["proposed", "active", "deprecated", "retired"]
          },
          "version": { "type": "string" },
          "owner": { "type": "string" },
          "purpose": { "type": "string" },
          "triggers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "instruction_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "memory_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "forbidden_actions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "quality_gates": {
            "type": "array",
            "items": { "type": "string" }
          },
          "escalation_rules": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
